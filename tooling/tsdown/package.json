{
  "$schema": "https://json.schemastore.org/package.json",
  "engines": {
    "node": ">=22.0.0"
  },
  "author": "@gentleduck contributors",
  "dependencies": {
    "@vitejs/plugin-react-swc": "^3.11.0",
    "tsdown": "0.18.3"
  },
  "description": "Shared tsdown build configuration for duck-www.",
  "version": "0.0.1",
  "keywords": [
    "tsdown",
    "tsdown-config"
  ],
  "license": "MIT",
  "main": "dist/index.mjs",
  "name": "@gentleduck/tsdown-config",
  "homepage": "https://github.com/gentleeduck/duck-www/tree/master/tooling/tsdown#readme",
  "bugs": {
    "url": "https://github.com/gentleeduck/duck-www/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gentleeduck/duck-www.git",
    "directory": "tooling/tsdown"
  },
  "packageManager": "bun@1.3.5",
  "private": true,
  "scripts": {
    "build": "tsdown index.ts --format esm --dts",
    "clean": "git clean -xdf .cache .turbo node_modules dist",
    "format": "biome format --write ./",
    "lint": "biome lint --write ./"
  },
  "type": "module",
  "types": "dist/index.d.mts"
}
