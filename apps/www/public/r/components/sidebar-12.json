    {
      "content": "import { Breadcrumb, BreadcrumbItem, BreadcrumbList, BreadcrumbPage } from '@gentleduck/registry-ui/breadcrumb'\nimport { Separator } from '@gentleduck/registry-ui/separator'\nimport { SidebarInset, SidebarProvider, SidebarTrigger } from '@gentleduck/registry-ui/sidebar'\nimport { AppSidebar } from './components/app-sidebar'\n\nexport default function Page() {\n  return (\n    <SidebarProvider>\n      <AppSidebar />\n      <SidebarInset>\n        <header className=\"sticky top-0 flex h-16 shrink-0 items-center gap-2 border-b bg-background px-4\">\n          <SidebarTrigger className=\"-ml-1\" />\n          <Separator className=\"mr-2 h-4\" orientation=\"vertical\" />\n          <Breadcrumb>\n            <BreadcrumbList>\n              <BreadcrumbItem>\n                <BreadcrumbPage>October 2024</BreadcrumbPage>\n              </BreadcrumbItem>\n            </BreadcrumbList>\n          </Breadcrumb>\n        </header>\n        <div className=\"flex flex-1 flex-col gap-4 p-4\">\n          <div className=\"grid auto-rows-min gap-4 md:grid-cols-5\">\n            {Array.from({ length: 20 }).map((_, i) => (\n              <div className=\"aspect-square rounded-xl bg-muted/50\" key={i} />\n            ))}\n          </div>\n        </div>\n      </SidebarInset>\n    </SidebarProvider>\n  )\n}\n",
      "path": "sidebar/sidebar-12/sidebar-12.tsx",
      "target": "components/sidebar-12.tsx",
      "type": "registry:block"
    },
    {
      "content": "import {\n  Sidebar,\n  SidebarContent,\n  SidebarFooter,\n  SidebarHeader,\n  SidebarMenu,\n  SidebarMenuButton,\n  SidebarMenuItem,\n  SidebarRail,\n  SidebarSeparator,\n} from '@gentleduck/registry-ui/sidebar'\nimport { Plus } from 'lucide-react'\nimport type * as React from 'react'\nimport { Calendars } from './calendars'\nimport { DatePicker } from './date-picker'\nimport { NavUser } from './nav-user'\n\n// This is sample data.\nconst data = {\n  calendars: [\n    {\n      items: ['Personal', 'Work', 'Family'],\n      name: 'My Calendars',\n    },\n    {\n      items: ['Holidays', 'Birthdays'],\n      name: 'Favorites',\n    },\n    {\n      items: ['Travel', 'Reminders', 'Deadlines'],\n      name: 'Other',\n    },\n  ],\n  user: {\n    avatar: '/avatars/01.png',\n    email: 'alex@gentleduck.org',\n    name: 'Alex Morgan',\n  },\n}\n\nexport function AppSidebar({ ...props }: React.ComponentProps<typeof Sidebar>) {\n  return (\n    <Sidebar {...props}>\n      <SidebarHeader className=\"h-16 border-sidebar-border border-b\">\n        <NavUser user={data.user} />\n      </SidebarHeader>\n      <SidebarContent>\n        <DatePicker />\n        <SidebarSeparator className=\"mx-0\" />\n        <Calendars calendars={data.calendars} />\n      </SidebarContent>\n      <SidebarFooter>\n        <SidebarMenu>\n          <SidebarMenuItem>\n            <SidebarMenuButton>\n              <Plus aria-hidden=\"true\" />\n              <span>New Calendar</span>\n            </SidebarMenuButton>\n          </SidebarMenuItem>\n        </SidebarMenu>\n      </SidebarFooter>\n      <SidebarRail />\n    </Sidebar>\n  )\n}\n",
      "path": "sidebar/sidebar-12/components/app-sidebar.tsx",
      "target": "components/app-sidebar.tsx",
      "type": "registry:block"
    },
    {
      "content": "import { Collapsible, CollapsibleContent, CollapsibleTrigger } from '@gentleduck/registry-ui/collapsible'\nimport {\n  SidebarGroup,\n  SidebarGroupContent,\n  SidebarGroupLabel,\n  SidebarMenu,\n  SidebarMenuButton,\n  SidebarMenuItem,\n  SidebarSeparator,\n} from '@gentleduck/registry-ui/sidebar'\nimport { Check, ChevronRight } from 'lucide-react'\nimport * as React from 'react'\n\nexport function Calendars({\n  calendars,\n}: {\n  calendars: {\n    name: string\n    items: string[]\n  }[]\n}) {\n  return (\n    <>\n      {calendars.map((calendar, index) => (\n        <React.Fragment key={calendar.name}>\n          <SidebarGroup className=\"py-0\" key={calendar.name}>\n            <Collapsible className=\"group/collapsible\" defaultOpen={index === 0}>\n              <SidebarGroupLabel\n                asChild\n                className=\"group/label w-full text-sidebar-foreground text-sm hover:bg-sidebar-accent hover:text-sidebar-accent-foreground\">\n                <CollapsibleTrigger>\n                  {calendar.name}{' '}\n                  <ChevronRight\n                    aria-hidden=\"true\"\n                    className=\"ml-auto transition-transform group-data-[open=true]/collapsible:rotate-90\"\n                  />\n                </CollapsibleTrigger>\n              </SidebarGroupLabel>\n              <CollapsibleContent>\n                <SidebarGroupContent>\n                  <SidebarMenu>\n                    {calendar.items.map((item, index) => (\n                      <SidebarMenuItem key={item}>\n                        <SidebarMenuButton>\n                          <div\n                            className=\"group/calendar-item flex aspect-square size-4 shrink-0 items-center justify-center rounded-sm border border-sidebar-border text-sidebar-primary-foreground data-[active=true]:border-sidebar-primary data-[active=true]:bg-sidebar-primary\"\n                            data-active={index < 2}>\n                            <Check\n                              aria-hidden=\"true\"\n                              className=\"hidden size-3 group-data-[active=true]/calendar-item:block\"\n                            />\n                          </div>\n                          {item}\n                        </SidebarMenuButton>\n                      </SidebarMenuItem>\n                    ))}\n                  </SidebarMenu>\n                </SidebarGroupContent>\n              </CollapsibleContent>\n            </Collapsible>\n          </SidebarGroup>\n          <SidebarSeparator className=\"mx-0\" />\n        </React.Fragment>\n      ))}\n    </>\n  )\n}\n",
      "path": "sidebar/sidebar-12/components/calendars.tsx",
      "target": "components/calendars.tsx",
      "type": "registry:block"
    },
    {
      "content": "import { Calendar } from '@gentleduck/registry-ui/calendar'\nimport { SidebarGroup, SidebarGroupContent } from '@gentleduck/registry-ui/sidebar'\n\nexport function DatePicker() {\n  return (\n    <SidebarGroup className=\"px-0\">\n      <SidebarGroupContent>\n        <Calendar className=\"[&_[role=gridcell].bg-accent]:bg-sidebar-primary [&_[role=gridcell].bg-accent]:text-sidebar-primary-foreground [&_[role=gridcell]]:w-[33px]\" />\n      </SidebarGroupContent>\n    </SidebarGroup>\n  )\n}\n",
      "path": "sidebar/sidebar-12/components/date-picker.tsx",
      "target": "components/date-picker.tsx",
      "type": "registry:block"
    },
    {
      "content": "'use client'\n\nimport { Avatar, AvatarFallback, AvatarImage } from '@gentleduck/registry-ui/avatar'\nimport {\n  DropdownMenu,\n  DropdownMenuContent,\n  DropdownMenuGroup,\n  DropdownMenuItem,\n  DropdownMenuLabel,\n  DropdownMenuSeparator,\n  DropdownMenuTrigger,\n} from '@gentleduck/registry-ui/dropdown-menu'\nimport { SidebarMenu, SidebarMenuButton, SidebarMenuItem, useSidebar } from '@gentleduck/registry-ui/sidebar'\nimport { BadgeCheck, Bell, ChevronsUpDown, CreditCard, LogOut, Sparkles } from 'lucide-react'\n\nexport function NavUser({\n  user,\n}: {\n  user: {\n    name: string\n    email: string\n    avatar: string\n  }\n}) {\n  const { isMobile } = useSidebar()\n\n  return (\n    <SidebarMenu>\n      <SidebarMenuItem>\n        <DropdownMenu>\n          <DropdownMenuTrigger asChild>\n            <SidebarMenuButton\n              className=\"data-[state=open]:bg-sidebar-accent data-[state=open]:text-sidebar-accent-foreground\"\n              size=\"lg\">\n              <Avatar className=\"h-8 w-8 rounded-lg\">\n                <AvatarImage alt={user.name} src={user.avatar} />\n                <AvatarFallback className=\"rounded-lg\">AM</AvatarFallback>\n              </Avatar>\n              <div className=\"grid flex-1 text-left text-sm leading-tight\">\n                <span className=\"truncate font-semibold\">{user.name}</span>\n                <span className=\"truncate text-xs\">{user.email}</span>\n              </div>\n              <ChevronsUpDown aria-hidden=\"true\" className=\"ml-auto size-4\" />\n            </SidebarMenuButton>\n          </DropdownMenuTrigger>\n          <DropdownMenuContent\n            align=\"start\"\n            className=\"w-(--gentleduck-dropdown-menu-trigger-width) min-w-56 rounded-lg\"\n            side={isMobile ? 'bottom' : 'right'}\n            sideOffset={4}>\n            <DropdownMenuLabel className=\"p-0 font-normal\">\n              <div className=\"flex items-center gap-2 px-1 py-1.5 text-left text-sm\">\n                <Avatar className=\"h-8 w-8 rounded-lg\">\n                  <AvatarImage alt={user.name} src={user.avatar} />\n                  <AvatarFallback className=\"rounded-lg\">AM</AvatarFallback>\n                </Avatar>\n                <div className=\"grid flex-1 text-left text-sm leading-tight\">\n                  <span className=\"truncate font-semibold\">{user.name}</span>\n                  <span className=\"truncate text-xs\">{user.email}</span>\n                </div>\n              </div>\n            </DropdownMenuLabel>\n            <DropdownMenuSeparator />\n            <DropdownMenuGroup>\n              <DropdownMenuItem>\n                <Sparkles aria-hidden=\"true\" />\n                Upgrade to Pro\n              </DropdownMenuItem>\n            </DropdownMenuGroup>\n            <DropdownMenuSeparator />\n            <DropdownMenuGroup>\n              <DropdownMenuItem>\n                <BadgeCheck aria-hidden=\"true\" />\n                Account\n              </DropdownMenuItem>\n              <DropdownMenuItem>\n                <CreditCard aria-hidden=\"true\" />\n                Billing\n              </DropdownMenuItem>\n              <DropdownMenuItem>\n                <Bell aria-hidden=\"true\" />\n                Notifications\n              </DropdownMenuItem>\n            </DropdownMenuGroup>\n            <DropdownMenuSeparator />\n            <DropdownMenuItem>\n              <LogOut aria-hidden=\"true\" />\n              Log out\n            </DropdownMenuItem>\n          </DropdownMenuContent>\n        </DropdownMenu>\n      </SidebarMenuItem>\n    </SidebarMenu>\n  )\n}\n",
      "path": "sidebar/sidebar-12/components/nav-user.tsx",
      "target": "components/nav-user.tsx",
      "type": "registry:block"
    }
