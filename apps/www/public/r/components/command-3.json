      "content": "'use client'\n\nimport {\n  Command,\n  CommandEmpty,\n  CommandGroup,\n  CommandInput,\n  CommandItem,\n  CommandList,\n  CommandSeparator,\n  CommandShortcut,\n} from '@gentleduck/registry-ui/command'\nimport { Calculator, Calendar, CreditCard, Settings, Smile, User } from 'lucide-react'\n\nexport default function CommandRtlDemo() {\n  return (\n    <Command className=\"h-fit w-80 border pt-0\" dir=\"rtl\">\n      <CommandInput placeholder=\"...اكتب امرا او ابحث\" />\n      <CommandList>\n        <CommandEmpty>لا توجد نتائج.</CommandEmpty>\n        <CommandGroup heading=\"اقتراحات\">\n          <CommandItem>\n            <Calendar />\n            <span>التقويم</span>\n          </CommandItem>\n          <CommandItem>\n            <Smile />\n            <span>بحث عن رموز تعبيرية</span>\n          </CommandItem>\n          <CommandItem disabled>\n            <Calculator />\n            <span>الالة الحاسبة</span>\n          </CommandItem>\n        </CommandGroup>\n        <CommandSeparator />\n        <CommandGroup heading=\"الاعدادات\">\n          <CommandItem>\n            <User />\n            <span>الملف الشخصي</span>\n            <CommandShortcut>⌘P</CommandShortcut>\n          </CommandItem>\n          <CommandItem>\n            <CreditCard />\n            <span>الفواتير</span>\n            <CommandShortcut>⌘B</CommandShortcut>\n          </CommandItem>\n          <CommandItem>\n            <Settings />\n            <span>الاعدادات</span>\n            <CommandShortcut>⌘S</CommandShortcut>\n          </CommandItem>\n        </CommandGroup>\n      </CommandList>\n    </Command>\n  )\n}\n",
